<script>
  const follower = document.querySelector('.follower');
  const constraintArea = document.querySelector('.constraint-area');



  // Initialize follower position in the center of the constraint area
  function initializeFollowerPosition() {
    const rect = constraintArea.getBoundingClientRect();
    const centerX = rect.left + (rect.width / 2);
    const centerY = rect.top + (rect.height / 2);
    const followerRadius = 15;

    follower.style.transform = `translate(${centerX - followerRadius}px, ${centerY - followerRadius}px)`;
  }

  // Call initialization when page loads
  //window.addEventListener('load', initializeFollowerPosition);
  initializeFollowerPosition();

  // Function to create circular binary pattern
  function createCircularBinary() {
    follower.innerHTML = ''; // Clear existing content
    const numDigits = 15; // Number of binary digits around the circle
    const radius = 10; // Radius of the circle

    for (let i = 0; i < numDigits; i++) {
      const digit = document.createElement('div');
      digit.className = 'binary-digit';
      digit.textContent = Math.random() > 0.5 ? '1' : '0';

      // Calculate position around the circle
      const angle = (i / numDigits) * 2 * Math.PI;
      const x = Math.cos(angle) * radius + 11; // Adjusted center offset for better centering
      const y = Math.sin(angle) * radius + 11; // Adjusted center offset for better centering

      digit.style.left = x + 'px';
      digit.style.top = y + 'px';

      follower.appendChild(digit);
    }
  }

  // Update binary display constantly
  function updateBinaryDisplay() {
    const digits = follower.querySelectorAll('.binary-digit');
    digits.forEach(digit => {
      digit.textContent = Math.random() > 0.5 ? '1' : '0';
    });
  }

  // Function to create binary border around constraint area
  function createBinaryBorder() {
    const numBorderDigits = 50; // Number of binary digits around the border
    const areaWidth = 150;
    const areaHeight = 100;

    for (let i = 0; i < numBorderDigits; i++) {
      const digit = document.createElement('div');
      digit.className = 'border-digit';
      digit.textContent = Math.random() > 0.5 ? '1' : '0';

      // Calculate position around the ellipse perimeter
      const angle = (i / numBorderDigits) * 2 * Math.PI;
      const radiusX = (areaWidth + 5) / 2;
      const radiusY = (areaHeight + 5) / 2;
      const x = Math.cos(angle) * radiusX + (areaWidth / 2) - 5; // Center and offset for digit width
      const y = Math.sin(angle) * radiusY + (areaHeight / 2) - 5; // Center and offset for digit height

      digit.style.left = x + 'px';
      digit.style.top = y + 'px';

      constraintArea.appendChild(digit);
    }
  }

  function createBinaryBorder2() {
    const numBorderDigits = 40; // Number of binary digits around the border
    const areaWidth = 150;
    const areaHeight = 100;

    for (let i = 0; i < numBorderDigits; i++) {
      const digit2 = document.createElement('div');
      digit2.className = 'border-digit';
      digit2.textContent = Math.random() > 0.5 ? '1' : '0';

      // Calculate position around the ellipse perimeter
      const angle = (i / numBorderDigits) * 2 * Math.PI;
      const radiusX = areaWidth / 2;
      const radiusY = areaHeight / 2;
      const x = Math.cos(angle) * radiusX + (areaWidth / 2) - 5; // Center and offset for digit width
      const y = Math.sin(angle) * radiusY + (areaHeight / 2) - 5; // Center and offset for digit height

      digit2.style.left = x + 'px';
      digit2.style.top = y + 'px';

      constraintArea.appendChild(digit2);
    }
  }

  // Update border binary display
  function updateBorderBinary() {
    const borderDigits = constraintArea.querySelectorAll('.border-digit');
    borderDigits.forEach(digit => {
      digit.textContent = Math.random() > 0.5 ? '1' : '0';
    });


    const borderDigits2 =constraintArea.querySelectorAll('.border-digit');
    borderDigits2.forEach(digit2 => {
      digit2.textContent = Math.random() > 0.5 ? '1' : '0';
    });

  }

  // Initialize the circular patterns
  createCircularBinary();
  createBinaryBorder();
  createBinaryBorder2();

  // Start the binary animations
  setInterval(updateBinaryDisplay, 100); // Update pupil every 100ms
  setInterval(updateBorderBinary, 80); // Update border every 80ms for slightly different timing

  document.addEventListener('mousemove', (event) => {
    const rect = constraintArea.getBoundingClientRect();
    const followerRadius = 15;

    // Calculate center and dimensions of the oval/circle
    const centerX = rect.left + rect.width / 2;
    const centerY = rect.top + rect.height / 2;
    const radiusX = (rect.width / 2) - followerRadius;
    const radiusY = (rect.height / 2) - followerRadius;

    // Get mouse position relative to center
    let x = event.clientX - centerX;
    let y = event.clientY - centerY;

    // Check if point is outside the ellipse and constrain it
    const ellipseEquation = (x * x) / (radiusX * radiusX) + (y * y) / (radiusY * radiusY);

    if (ellipseEquation > 1) {
      // Point is outside ellipse, project it onto the ellipse boundary
      const angle = Math.atan2(y, x);
      x = radiusX * Math.cos(angle);
      y = radiusY * Math.sin(angle);
    }

    // Convert back to absolute coordinates
    const finalX = centerX + x;
    const finalY = centerY + y;

    follower.style.transform = `translate(${finalX - followerRadius}px, ${finalY - followerRadius}px)`;
  });
